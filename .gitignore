# Android Studio / Gradle local files
.gradle/
.idea/
local.properties
*.iml
.DS_Store

# Android / Gradle build outputs
build/
**/build/
android-app/.cxx/
**/.cxx/
.externalNativeBuild/

# Native build artifacts
# We generally want to ignore built objects and binaries.
# libvbam_libretro.so is built by scripts and copied to jniLibs.
*.o
*.a
*.so
*.dll
*.dylib
*.exe

# Generated JNI libs for Android
# These are copied from the build/ directory by Gradle tasks.
android-app/src/main/jniLibs/

# Editor / tooling
.vscode/
.claude/
.vs/
compile_commands.json
.cache/

# Vim swap files
*.sw?
*.un~
